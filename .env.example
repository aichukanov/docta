NODE_OPTIONS=--max-old-space-size=32768

# Analytics (опционально)
# MIXPANEL_TOKEN=your_mixpanel_token
# GTAG_ID=your_gtag_id

# Cloudflare
CLOUDFLARE_TOKEN=your_cloudflare_token

# База данных
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=docta_me
DB_PORT=3306

# OAuth Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth Facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# OAuth Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Base URL (ОБЯЗАТЕЛЬНО - используется для OAuth redirect URI и email ссылок)
# Для локальной разработки:
BASE_URL=http://localhost:3000
# Для production:
# BASE_URL=https://yourdomain.com

# Файлы верификации отзывов (чеки/направления) — НЕпубличная директория.
# Дефолт: <project>/storage/verifications
# VERIFICATIONS_DIR=/home/docta/verifications

# E2E тестирование
E2E_BASE_URL=http://localhost:3000

# Ngrok (опционально, для тестирования OAuth с localhost)
# NGROK_HOST=your-subdomain.ngrok-free.dev

# Stripe (платные услуги клиник). Без ключей оплата отключена,
# остальной биллинг (каталог, история) работает.
# Test mode ключи: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # из настроек webhook endpoint'а (или stripe listen)
# NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_domain.com
MAILGUN_FROM_EMAIL=noreply@your_domain.com
MAILGUN_FROM_NAME=Your App Name
MAILGUN_API_URL=https://api.mailgun.net
# Для EU региона:
# MAILGUN_API_URL=https://api.eu.mailgun.net
