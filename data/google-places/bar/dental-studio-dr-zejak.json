      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25SNmVrVkZUa2QxWWpkZmJtdFllalpVUmxGR2IwRRAB!2m1!1s0x134e7350e86cbd49:0xf217fb46902dfa86"
