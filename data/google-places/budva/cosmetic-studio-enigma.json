      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnSUNyMVBXaENnEAE!2m1!1s0x134dd49738122959:0x3fe8446d82fa1990"
