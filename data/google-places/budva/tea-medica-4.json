      },
      "publishTime": "2025-03-11T13:24:00.160438Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=ChZDSUhNMG9nS0VJQ0FnTURRd2VHQ0l3EAE&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnTURRd2VHQ0l3EAE!2m1!1s0x134dd490acc7cd4d:0x42da653f63131824"
