      },
      "publishTime": "2024-09-04T11:59:21.924698Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=ChZDSUhNMG9nS0VJQ0FnSUNIcHEzQll3EAE&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnSUNIcHEzQll3EAE!2m1!1s0x134c3b7e5eb3f90d:0x8f1babda348730c2"
