      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT21oVloyeHVhVUl3UVVoU05VZFVZVXBDU1RWV2FuYxAB!2m1!1s0x134c3b7e5eb3f90d:0x8f1babda348730c2"
