      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChdDSUhNMG9nS0VJQ0FnSURfbjVuSzRnRRAB!2m1!1s0x134c3d4ed2a55333:0xb6926817e6bf5712"
