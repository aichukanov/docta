      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25sS1gxOUplWFZGU1VwbmJGZEVPRUYwZGkxMk5YYxAB!2m1!1s0x134c2d49b37ca673:0x8554bcf109a0c9e4"
