    {
      "name": "places/ChIJc6Z8s0ktTBMR5MmgCfG8VIU/reviews/Ci9DQUlRQUNvZENodHljRjlvT205eFVWcGliblY2YlhkWE1GbFFkakYyVFRWdGNWRRAB",
      "relativePublishTimeDescription": "пре 4 недеље",
      "rating": 2,
      "text": {
        "text": "Неко ми је заказао преглед за магнетну резонанцу - када сам платио, дао сам своју имејл адресу итд. да бих добио извештај. Послали су мој извештај особи која је заказала преглед. Дељење приватних личних података - ужаснут сам, нема поверљивости, нема никаквог професионализма.",
        "languageCode": "sr"
      },
      "originalText": {
        "text": "I had someone make the MRI appointment for me - when I paid, I gave my email address etc to receive my report. They sent my report to the person who made the appointment. Sharing private personal information - I am appalled, no confidentiality, no professionalism at all.",
        "languageCode": "en"
      },
      "authorAttribution": {
        "displayName": "Dorothea Lawrence",
        "uri": "https://www.google.com/maps/contrib/100229356000442537019/reviews",
        "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjWJaTYhiYy8ZawhOgptBXkuirWnZlhnKUF9SksXYz7x_u3Mi24D=s128-c0x00000000-cc-rp-mo"
      },
      "publishTime": "2026-02-17T17:19:42.983959362Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT205eFVWcGliblY2YlhkWE1GbFFkakYyVFRWdGNWRRAB&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT205eFVWcGliblY2YlhkWE1GbFFkakYyVFRWdGNWRRAB!2m1!1s0x134c2d49b37ca673:0x8554bcf109a0c9e4"
    },
    {
      "name": "places/ChIJc6Z8s0ktTBMR5MmgCfG8VIU/reviews/Ci9DQUlRQUNvZENodHljRjlvT2t4M1VWZFFRVkZTZEhndGIzQjFhMFZyTVhGeWFtYxAB",
      "relativePublishTimeDescription": "пре 4 месеца",
      "rating": 5,
      "text": {
        "text": "Љубазно особље, услужно, пажљиво и професионално. Топло се препоручује.",
