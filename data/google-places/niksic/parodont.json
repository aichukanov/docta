      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChdDSUhNMG9nS0VJQ0FnSUNfd1lDOW9nRRAB!2m1!1s0x134da84f6a5fc45f:0x8752b45f2af6edab"
