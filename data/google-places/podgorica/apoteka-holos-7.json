      "publishTime": "2024-06-11T13:45:51.583170Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=ChZDSUhNMG9nS0VJQ0FnSUR6M3RhQlV3EAE&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnSUR6M3RhQlV3EAE!2m1!1s0x134debd672c47a33:0x8f6a6832a470f838"
