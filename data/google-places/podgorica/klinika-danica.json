      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChdDSUhNMG9nS0VJQ0FnSURiMVozZTVnRRAB!2m1!1s0x134dead87cbd518b:0x3f463b3dbb48eec1"
