		{
			"name": "reviews/ChdDSUhNMG9nS0VJQ0FnSURhOXBMdndRRRAB",
			"relativePublishTimeDescription": "4 года назад",
			"rating": 5,
			"text": {
				"text": "Very professional, organized and quick result performed by friendly staff. Both women who handled my case were wonderful and spoke English. I made an appointment via email, arrived on time and given a form to fill out at the Document window. After that was entered into the computer and I paid via contactless card and given a receipt, I was swabbed at the second window. Results arrived via email within 4 hours. No queue when I went, just people milling around and not moving to side. Wear a mask.",
				"languageCode": "en"
			},
			"originalText": {
				"text": "Very professional, organized and quick result performed by friendly staff. Both women who handled my case were wonderful and spoke English. I made an appointment via email, arrived on time and given a form to fill out at the Document window. After that was entered into the computer and I paid via contactless card and given a receipt, I was swabbed at the second window. Results arrived via email within 4 hours. No queue when I went, just people milling around and not moving to side. Wear a mask.",
				"languageCode": "en"
			},
