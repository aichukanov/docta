      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2tOT2JWWXRObXRpVUhNNVlXNUNibEJCTFRSSGNVRRAB!2m1!1s0x134deb6aab9d60db:0xbfa20524a83ca79c"
