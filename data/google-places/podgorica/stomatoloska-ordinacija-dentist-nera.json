      },
      "publishTime": "2024-07-14T16:56:35.003112Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=ChZDSUhNMG9nS0VJQ0FnSURyLUx2YlpBEAE&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnSURyLUx2YlpBEAE!2m1!1s0x134deb05dc1a788b:0x8f53b3f2bad64508"
