      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChdDSUhNMG9nS0VJQ0FnSUNHMi11TnVBRRAB!2m1!1s0x134deb219ec52e85:0x1c8587662fc423d3"
