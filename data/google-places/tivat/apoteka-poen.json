      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xsNFVVWXdVazh0T1c5TWNVVkJlSFJHWW1kZlFXYxAB!2m1!1s0x134c319d1d18090f:0xdaa2f5464c3b7e33"
